        "page": 0,
        "size": 20,
        "sortBy": "startDateTime",
        "sortOrder": "asc"
      },
      "responses": {
        "200": {
          "description": "Club events retrieved successfully",
          "body": {
            "content": [
              {
                "id": "string",
                "title": "string",
                "shortDescription": "string",
                "imageUrl": "string",
                "location": "string",
                "startDateTime": "ISO_DATE",
                "endDateTime": "ISO_DATE",
                "formattedDate": "string",
                "formattedTime": "string",
                "timeUntilEvent": "string",
                "duration": "string",
                "attendeeCount": 0,
                "maxAttendees": 0,
                "isRegistered": true,
                "canRegister": true,
                "isFull": true,
                "clubId": "string",
                "clubName": "string",
                "clubLogo": "string",
                "organizerName": "string",
                "status": "UPCOMING",
                "isPublic": true,
                "requiresApproval": true,
                "capacityPercentage": 0,

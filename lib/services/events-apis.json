            "hasNext": true,
            "hasPrevious": true,
            "first": true,
            "last": true,
            "paginationInfo": "string",
            "resultsInfo": "string"
          }
        },
        "404": {
          "description": "Club not found",
          "body": "Same schema as 200 response"
        }
      }
    },


                "organizerName": "string",
                "status": "UPCOMING",
                "isPublic": true,
                "requiresApproval": true,
                "capacityPercentage": 0,
                "eventStatusText": "string",
                "pastEvent": true,
                "upcoming": true,
                "ongoing": true,
                "attendeeStatus": "string"
              }

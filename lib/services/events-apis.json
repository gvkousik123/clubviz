    "GET_/events/my-organized-events": {
      "description": "Get events organized by user",
      "params": {
        "page": 0,
        "size": 20,
        "sortBy": "startDateTime",
        "sortOrder": "asc"
      },
      "responses": {
        "200": {
          "description": "User's organized events retrieved successfully",
          "body": "Same schema as GET_/events/list response"
        },
        "401": {
          "description": "Authentication required",
          "body": "Same schema as GET_/events/list response"
        },
        "404": {
          "description": "User not found",
          "body": "Same schema as GET_/events/list response"
        }
      }
    },

    "GET_/events/my-registrations": {
      "description": "Get user's registered events",
      "params": {
        "page": 0,
        "size": 20,

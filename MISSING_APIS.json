    "waitlistManagement": {
      "title": "User - Waitlist Management",
      "priority": "Low",
      "endpoints": [
        {
          "id": "join-waitlist",
          "title": "Join Waitlist",
          "description": "Add user to waitlist when desired table/event is fully booked",
          "method": "POST",
          "endpoint": "/clubs/{clubId}/waitlist",
          "authentication": "Required (Bearer Token)",
          "requestBody": {
            "type": "object",
            "properties": {
              "preferredDateTime": {
                "type": "string",
                "format": "date-time",
                "description": "Preferred date and time for booking"
              },
              "guestCount": {
                "type": "integer",
                "description": "Number of guests"
              },
              "notificationPreference": {
                "type": "string",
                "enum": ["SMS", "EMAIL", "PUSH", "ALL"],
                "description": "How to notify when slot is available"
              }
            },
            "required": ["preferredDateTime", "guestCount"]
          },
          "responseExample": {
            "success": true,
            "data": {
              "waitlistId": "waitlist_001",
              "clubId": "club_001",
              "userId": "user_123",
              "position": 5,
              "preferredDateTime": "2026-01-25T22:00:00Z",
              "guestCount": 4,
              "joinedAt": "2026-01-20T10:30:00Z",
              "estimatedWaitTime": "2-3 days"
            }
          }

{
  "baseUrl": "https://clubwiz.in",
  "missingApis": {
    "eventTicketing": {
      "title": "Event Ticketing & Booking (User Side)",
      "priority": "High",
      "endpoints": [
        {
          "id": "purchase-event-tickets",
          "title": "Purchase Event Tickets",
          "description": "Allow users to buy specific event tickets with selection of ticket types and quantities",
          "method": "POST",
          "endpoint": "/events/{eventId}/tickets/purchase",
          "authentication": "Required (Bearer Token)",
          "requestBody": {
            "type": "object",
            "properties": {
              "ticketSelections": {
                "type": "array",
                "description": "Array of ticket type selections",
                "items": {
                  "type": "object",
                  "properties": {
                    "ticketTypeId": {
                      "type": "string",
                      "description": "ID of the ticket type (e.g., VIP, Regular, Standard)"
                    },
                    "quantity": {
                      "type": "integer",
                      "description": "Number of tickets to purchase for this type"
                    }
                  }
                }
              },
              "totalTickets": {
                "type": "integer",
                "description": "Total number of tickets being purchased"
              },
              "promoCode": {
                "type": "string",
                "description": "Optional promo code for discount"
              },
              "paymentMethod": {
                "type": "string",
                "enum": ["CREDIT_CARD", "DEBIT_CARD", "UPI", "WALLET"],
                "description": "Payment method for the booking"
              }
            },
            "required": ["ticketSelections", "totalTickets"]
          },
          "responseExample": {
            "success": true,
            "data": {
              "bookingId": "booking_123456",
              "eventId": "event_789",
              "eventTitle": "EDM Night 2025",
              "ticketDetails": [
                {
                  "ticketTypeId": "vip_001",
                  "ticketType": "VIP",
                  "quantity": 2,
                  "pricePerTicket": 1000,
                  "subtotal": 2000
                },
                {
                  "ticketTypeId": "regular_001",
                  "ticketType": "Regular",
                  "quantity": 1,
                  "pricePerTicket": 500,
                  "subtotal": 500
                }
              ],
              "totalPrice": 2500,
              "discount": 250,
              "finalPrice": 2250,
              "status": "CONFIRMED",
              "bookingDate": "2026-01-20T10:30:00Z",
              "eventDate": "2026-01-25T21:00:00Z"
            }
          }
        },
        {
          "id": "get-user-tickets",
          "title": "Get User Purchased Tickets",
          "description": "Retrieve all event tickets purchased by the logged-in user",
          "method": "GET",
          "endpoint": "/user/tickets",
          "authentication": "Required (Bearer Token)",
          "queryParameters": {
            "page": {
              "type": "integer",
              "default": 1,
              "description": "Page number for pagination"
            },
            "limit": {
              "type": "integer",
              "default": 10,
              "description": "Number of tickets per page"
            },
            "status": {
              "type": "string",
              "enum": ["ACTIVE", "USED", "CANCELLED", "EXPIRED"],
              "description": "Filter by ticket status"
            },
            "eventId": {
              "type": "string",
              "description": "Optional filter by specific event"
            }
          },
          "responseExample": {
            "success": true,
            "data": {
              "tickets": [
                {
                  "ticketId": "ticket_001",
                  "bookingId": "booking_123456",
                  "eventId": "event_789",
                  "eventTitle": "EDM Night 2025",
                  "eventDate": "2026-01-25T21:00:00Z",
                  "ticketType": "VIP",
                  "ticketNumber": "ABC123456",
                  "qrCode": "data:image/png;base64,...",
                  "status": "ACTIVE",
                  "purchaseDate": "2026-01-20T10:30:00Z",
                  "price": 1000,
                  "entryAllowed": true
                }
              ],
              "pagination": {
                "totalElements": 5,
                "totalPages": 1,
                "currentPage": 1
              }
            }
          }
        },
        {
          "id": "get-ticket-qr-code",
          "title": "Get Ticket QR Code",
          "description": "Generate and retrieve QR code for a specific ticket for entry validation",
          "method": "GET",
          "endpoint": "/tickets/{ticketId}/qr-code",
          "authentication": "Required (Bearer Token)",
          "responseExample": {
            "success": true,
            "data": {
              "ticketId": "ticket_001",
              "qrCode": "data:image/png;base64,...",
              "qrData": "TICKET_ABC123456_2026_01_25",
              "expiresAt": "2026-01-25T23:59:59Z"
            }
          }
        },
        {
          "id": "validate-ticket-qr",
          "title": "Validate Ticket QR Code (Admin/Entry Point)",
          "description": "Backend endpoint to validate QR code at entry point (Admin endpoint)",
          "method": "POST",
          "endpoint": "/admin/tickets/validate-qr",
          "authentication": "Required (Bearer Token - Admin)",
          "requestBody": {
            "type": "object",
            "properties": {
              "qrData": {
                "type": "string",
                "description": "QR code data scanned"
              },
              "clubId": {
                "type": "string",
                "description": "Club/venue ID for validation"
              }
            },
            "required": ["qrData", "clubId"]
          },
          "responseExample": {
            "success": true,
            "data": {
              "valid": true,
              "ticketId": "ticket_001",
              "userName": "John Doe",
              "ticketType": "VIP",
              "eventTitle": "EDM Night 2025",
              "message": "Entry granted"
            }
          }
        }
      ]
    },
    "clubAdminBookingManagement": {
      "title": "Club Admin - Booking Management",
      "priority": "High",
      "endpoints": [
        {
          "id": "get-club-bookings",
          "title": "Get Club Bookings",
          "description": "Retrieve all bookings for a specific club with filters for date, status, and type",
          "method": "GET",
          "endpoint": "/clubs/{clubId}/bookings",
          "authentication": "Required (Bearer Token - Club Admin/Owner)",
          "queryParameters": {
            "date": {
              "type": "string",
              "format": "date",
              "description": "Filter by booking date (YYYY-MM-DD)"
            },
            "startDate": {
              "type": "string",
              "format": "date",
              "description": "Filter bookings from this date onwards"
            },
            "endDate": {
              "type": "string",
              "format": "date",
              "description": "Filter bookings up to this date"
            },
            "status": {
              "type": "string",
              "enum": ["CONFIRMED", "PENDING", "CANCELLED", "NO_SHOW"],
              "description": "Filter by booking status"
            },
            "type": {
              "type": "string",
              "enum": ["TABLE", "EVENT", "ALL"],
              "description": "Filter by booking type"
            },
            "page": {
              "type": "integer",
              "default": 1,
              "description": "Page number for pagination"
            },
            "limit": {
              "type": "integer",
              "default": 20,
              "description": "Number of bookings per page"
            }
          },
          "responseExample": {
            "success": true,
            "data": {
              "bookings": [
                {
                  "bookingId": "booking_001",
                  "userId": "user_123",
                  "userName": "John Doe",
                  "userPhone": "9876543210",
                  "bookingType": "TABLE",
                  "bookingDate": "2026-01-20T15:00:00Z",
                  "guestCount": 4,
                  "tableNumber": "T5",
                  "totalPrice": 5000,
                  "status": "CONFIRMED",
                  "notes": "VIP customer",
                  "checkInTime": null,
                  "checkOutTime": null
                }
              ],
              "pagination": {
                "totalElements": 25,
                "totalPages": 2,
                "currentPage": 1
              }
            }
          }
        },
        {
          "id": "approve-reject-booking",
          "title": "Approve/Reject Club Booking",
          "description": "Allow club admin to manually approve or reject a pending booking",
          "method": "POST",
          "endpoint": "/clubs/{clubId}/bookings/{bookingId}/manage",
          "authentication": "Required (Bearer Token - Club Admin/Owner)",
          "requestBody": {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "enum": ["APPROVE", "REJECT"],
                "description": "Action to perform on the booking"
              },
              "reason": {
                "type": "string",
                "description": "Reason for rejection (required if action is REJECT)"
              },
              "notes": {
                "type": "string",
                "description": "Optional notes for the booking"
              }
            },
            "required": ["action"]
          },
          "responseExample": {
            "success": true,
            "data": {
              "bookingId": "booking_001",
              "status": "CONFIRMED",
              "message": "Booking approved successfully",
              "updatedAt": "2026-01-20T15:30:00Z"
            }
          }
        },
        {
          "id": "check-in-booking",
          "title": "Check-In Booking",
          "description": "Record guest check-in at the club",
          "method": "POST",
          "endpoint": "/clubs/{clubId}/bookings/{bookingId}/check-in",
          "authentication": "Required (Bearer Token - Club Admin)",
          "requestBody": {
            "type": "object",
            "properties": {
              "actualGuestCount": {
                "type": "integer",
                "description": "Actual number of guests who arrived"
              },
              "notes": {
                "type": "string",
                "description": "Optional check-in notes"
              }
            }
          },
          "responseExample": {
            "success": true,
            "data": {
              "bookingId": "booking_001",
              "checkInTime": "2026-01-20T21:30:00Z",
              "actualGuestCount": 4,
              "status": "CHECKED_IN"
            }
          }
        },
        {
          "id": "check-out-booking",
          "title": "Check-Out Booking",
          "description": "Record guest check-out and finalize booking",
          "method": "POST",
          "endpoint": "/clubs/{clubId}/bookings/{bookingId}/check-out",
          "authentication": "Required (Bearer Token - Club Admin)",
          "requestBody": {
            "type": "object",
            "properties": {
              "additionalCharges": {
                "type": "number",
                "description": "Any additional charges incurred"
              },
              "notes": {
                "type": "string",
                "description": "Optional check-out notes"
              }
            }
          },
          "responseExample": {
            "success": true,
            "data": {
              "bookingId": "booking_001",
              "checkOutTime": "2026-01-21T02:00:00Z",
              "totalCharges": 5200,
              "status": "COMPLETED"
            }
          }
        }
      ]
    },
    "clubAdminAnalytics": {
      "title": "Club Admin - Analytics & Dashboard",
      "priority": "Medium",
      "endpoints": [
        {

    "reviewsAndRatings": {
      "title": "Reviews & Ratings System",
      "priority": "Medium",
      "endpoints": [
        {
          "id": "submit-club-review",
          "title": "Submit Club Review",
          "description": "Allow users to submit a review and rating for a club",
          "method": "POST",
          "endpoint": "/clubs/{clubId}/reviews",
          "authentication": "Required (Bearer Token)",
          "requestBody": {
            "type": "object",
            "properties": {
              "rating": {
                "type": "number",
                "minimum": 1,
                "maximum": 5,
                "description": "Rating out of 5"
              },
              "title": {
                "type": "string",
                "maxLength": 100,
                "description": "Review title"
              },
              "reviewText": {
                "type": "string",
                "maxLength": 1000,
                "description": "Detailed review text"
              },
              "aspects": {
                "type": "object",
                "properties": {
                  "ambiance": { "type": "number", "minimum": 1, "maximum": 5 },
                  "service": { "type": "number", "minimum": 1, "maximum": 5 },
                  "food": { "type": "number", "minimum": 1, "maximum": 5 },
                  "music": { "type": "number", "minimum": 1, "maximum": 5 },
                  "pricing": { "type": "number", "minimum": 1, "maximum": 5 }
                },
                "description": "Ratings for specific aspects"
              },
              "visitDate": {
                "type": "string",
                "format": "date",
                "description": "Date of visit"
              }
            },
            "required": ["rating", "title", "reviewText"]
          },
          "responseExample": {
            "success": true,
            "data": {
              "reviewId": "review_001",
              "clubId": "club_001",
              "userId": "user_123",
              "userName": "John Doe",
              "rating": 4.5,
              "title": "Amazing ambiance!",
              "reviewText": "Had a wonderful time at this club...",
              "createdAt": "2026-01-20T10:30:00Z",
              "verified": true
